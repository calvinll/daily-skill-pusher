APP_ENV=development
APP_TIMEZONE=Asia/Shanghai
WEB_PORT=4173
CRON_EXPRESSION=5 9 * * *
SCHEDULER_ENABLED=true
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me
# Optional: 飞书机器人开启“签名校验”后填写
FEISHU_BOT_SECRET=
# Optional: 飞书机器人开启“关键词校验”后填写；发送时会自动补到卡片标题
FEISHU_REQUIRED_KEYWORD=
DATA_DIR=./data
DAYS_TO_AVOID_REPEAT=14
AVOID_SAME_CATEGORY_DAYS=2
DAILY_COUNT=1
WEEKDAY_THEME_MONDAY=high-frequency-productivity
WEEKDAY_THEME_TUESDAY=setup-workflow
WEEKDAY_THEME_WEDNESDAY=official-high-value
WEEKDAY_THEME_THURSDAY=team-collaboration
WEEKDAY_THEME_FRIDAY=learning-path
